# Core runtime
DOCMESH_ENV=development
DOCMESH_HEALTHCHECK_ENABLED=true

# Keycloak (required by docmesh-py-core settings validation)
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=docmesh
KEYCLOAK_CLIENT_ID=docmesh-backend
KEYCLOAK_CLIENT_SECRET=replace-me

# Metadata store
POSTGRES_DSN=postgresql://docmesh:replace-me@postgres.example.com:5432/docmesh

# Object storage
MINIO_ENDPOINT=minio.example.com:9000
MINIO_ACCESS_KEY=minio-access-key
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET=documents
MINIO_SECURE=false
