# This file is a deployment template and is not loaded automatically.
# Replace all placeholder endpoints and secrets before enabling startup checks.

# -----------------------------------------------------------------------------
# Common runtime and DMS SDK assembly
# -----------------------------------------------------------------------------
DOCMESH_ENV=development
DOCMESH_HEALTHCHECK_ENABLED=false
DMS_METADATA_BACKEND=postgresql
DMS_CONFIGURATION_STRICT=true

# -----------------------------------------------------------------------------
# fastapi-core AppConfig
# For the Traefik /dms deployment, use ROOT_PATH=/dms and TOKEN_URL=/dms/token.
# -----------------------------------------------------------------------------
ROOT_PATH=
TOKEN_URL=/token
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_CREDENTIALS=false
READINESS_PARALLEL=false
READINESS_TIMEOUT_SECONDS=5
READINESS_OVERALL_TIMEOUT_SECONDS=15
DOCMESH_LOG_LEVEL=INFO
APP_LOG_PATH=
APP_LOG_JSON=true
APP_LOG_FORCE=false

# The document API uses Keycloak authentication. Every required service must
# also be present in DOCMESH_SERVICES.
DOCMESH_SERVICES=keycloak
READINESS_REQUIRED_SERVICES=keycloak

# -----------------------------------------------------------------------------
# Keycloak
# -----------------------------------------------------------------------------
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=docmesh
KEYCLOAK_CLIENT_ID=docmesh-document-service
KEYCLOAK_CLIENT_SECRET=replace-me
KEYCLOAK_CLIENT_PUBLIC=false
KEYCLOAK_VERIFY_SSL=true

# Used only by password-grant integration tests.
# KEYCLOAK_TOKEN_USERNAME=
# KEYCLOAK_TOKEN_PASSWORD=replace-me

# -----------------------------------------------------------------------------
# Metadata store: PostgreSQL
# dms-core v0.4.0 requires individual fields; do not set POSTGRES_DSN.
# -----------------------------------------------------------------------------
POSTGRES_HOST=postgres.example.com
POSTGRES_PORT=5432
POSTGRES_DB=docmesh
POSTGRES_USER=docmesh
POSTGRES_PASSWORD=replace-me

# -----------------------------------------------------------------------------
# Object storage: MinIO
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=minio.example.com:9000
MINIO_ACCESS_KEY=minio-access-key
MINIO_SECRET_KEY=replace-me
MINIO_BUCKET=documents
MINIO_SECURE=true
