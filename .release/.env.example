# DocMesh Document Service - 환경변수 설정 예시
# 실제 배포 시 이 파일을 .env 로 복사하여 값을 채워주세요

# 설정 파일 경로
CONFIG_PATH=.devcontainer/config.yaml

# Keycloak
KEYCLOAK__HTTP_URL=http://keycloak:8080
KEYCLOAK__REALM=master
KEYCLOAK__CLIENT_ID=docmesh
KEYCLOAK__CLIENT_SECRET=<your-client-secret>

# MinIO
MINIO__ENDPOINT=minio:9000
MINIO__ACCESS_KEY=admin
MINIO__SECRET_KEY=<your-minio-secret>
MINIO__BUCKET=documents
MINIO__PRESIGNED_EXPIRES_SEC=900

# Database (Postgres)
DB__HOST=document-db
DB__PORT=5432
DB__NAME=docmesh
DB__USER=postgres
DB__PASSWORD=<your-db-password>
# DB__URL=postgresql+psycopg2://postgres:password@document-db:5432/docmesh  # 직접 DSN 지정 시 위 항목 무시
DB__SSLMODE=prefer
DB__POOL_SIZE=5

# Logging
LOGGING__LEVEL=INFO

# NATS
NATS__SERVERS=nats://nats:4222
NATS__NAME=docmesh-doc
NATS__CONNECT_TIMEOUT=2
NATS__MAX_RECONNECT_ATTEMPTS=60
NATS__RECONNECT_TIME_WAIT_MS=2000
NATS__QUEUE_GROUP=default-workers
