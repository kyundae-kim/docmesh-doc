# Common
TZ='Asia/Seoul'
LOGGING_LEVEL='INFO'
ENV="dev"

# fastapi
root_path="/doc"

# keycloak
KEYCLOAK_HTTP_URL="http://http://192.168.219.106:8080/"
KEYCLOAK_MANAGE_URL="http://http://192.168.219.106:9000/"
