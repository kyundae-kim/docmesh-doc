# Common
TZ='Asia/Seoul'
LOGGING_LEVEL='INFO'
ENV="dev"

# fastapi
root_path="/doc"

# keycloak
KEYCLOAK_HTTP_URL="http://192.168.219.106:8080/"
KEYCLOAK_MANAGE_URL="http://192.168.219.106:9000/"
KEYCLOAK_REALM="restapi"
KEYCLOAK_CLIENT_ID="fastapi"

# CORS
CORS_ORIGINS="*"
CORS_CREDENTIALS=false

# auth
AUTH_VERTIFY_JWT=false

# minio
MINIO__ENDPOINT="192.168.219.106:9000"
MINIO__ACCESS_KEY="admin"
MINIO__SECRET_KEY="password123"
MINIO__BUCKET_NAME="docmesh"
MINIO__SECURE=false

# PostgresSQL
DB__HOST='postgres'
DB__PORT=5432
DB__NAME='postgres'
DB__USER='postgres'
DB__PASSWORD='postgres'
DB__AUTH_METHOD='password'
DB__SSLMODE='prefer'
DB__CONNECT_TIMEOUT=5
DB__ECHO=false

# hermes-agent
HERMES_HOME=".hermes"

# NATS
NATS__SERVERS=nats://192.168.219.106:4222
NATS__NAME=docmesh-doc
NATS__CONNECT_TIMEOUT=2
NATS__MAX_RECONNECT_ATTEMPTS=60
NATS__RECONNECT_TIME_WAIT_MS=2000
NATS__QUEUE_GROUP=default-workers
