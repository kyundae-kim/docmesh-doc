# DocMesh Document Service environment example
# Copy to .env (local) or .release/.env (docker deploy) and fill secrets.
# fastapi-core EnvConfig uses nested keys with '__'.

# hermes-agent
HERMES_HOME="/workspaces/docmesh-doc/.hermes"
WIKI_PATH='/workspaces/docmesh-doc/wiki'

# -----------------------------------------------------------------------------
# Common runtime and DMS SDK assembly
# -----------------------------------------------------------------------------
DOCMESH_ENV=development
DOCMESH_HEALTHCHECK_ENABLED=false
DMS_METADATA_BACKEND=postgresql
DMS_CONFIGURATION_STRICT=true

# -----------------------------------------------------------------------------
# fastapi-core AppConfig
# For the Traefik /dms deployment, use ROOT_PATH=/dms and TOKEN_URL=/dms/token.
# -----------------------------------------------------------------------------
ROOT_PATH=/
TOKEN_URL=/token
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_CREDENTIALS=false
READINESS_PARALLEL=false
READINESS_TIMEOUT_SECONDS=5
READINESS_OVERALL_TIMEOUT_SECONDS=15
DOCMESH_LOG_LEVEL=INFO
APP_LOG_PATH=
APP_LOG_JSON=true
APP_LOG_FORCE=false

# Core runtime
DOCMESH_SERVICES='postgres,minio,keycloak'
DOCMESH_REQUIRED_SERVICES='postgres,minio,keycloak'

# Keycloak (required by docmesh-py-core settings validation)
KEYCLOAK_URL=http://192.168.219.106:8080
KEYCLOAK_REALM=docmesh
KEYCLOAK_CLIENT_ID=document
KEYCLOAK_CLIENT_SECRET=replace-me
KEYCLOAK_TOKEN_GRANT_TYPE=password
KEYCLOAK_TOKEN_USERNAME=test
KEYCLOAK_TOKEN_PASSWORD=test

# Metadata store
# POSTGRES_DSN='postgresql+psycopg://postgres:postgres@postgres:5432/postgres'
POSTGRES_HOST='postgres'
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Object storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=default
MINIO_SECURE=false




# Runtime
TZ='Asia/Seoul'
