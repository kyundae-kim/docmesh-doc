# Common
TZ='Asia/Seoul'
LOGGING_LEVEL='INFO'
ENV="dev"

# fastapi
root_path="/doc"

# keycloak
KEYCLOAK_HTTP_URL="http://keycloak:8080/"
KEYCLOAK_MANAGE_URL="http://keycloak:9000/"
KEYCLOAK_REALM="restapi"
KEYCLOAK_CLIENT_ID="fastapi"

# CORS
CORS_ORIGINS="*"
CORS_CREDENTIALS=false

# auth
AUTH_VERTIFY_JWT=false

# minio
MINIO__ENDPOINT="localhost:9000"
MINIO__ACCESS_KEY="admin"
MINIO__SECRET_KEY="password123"
MINIO__BUCKET_NAME="docmesh"
MINIO__SECURE=false

# hermes-agent
HERMES_HOME="./.hermes"