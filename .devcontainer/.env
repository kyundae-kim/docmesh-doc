# DocMesh Document Service environment example
# Copy to .env (local) or .release/.env (docker deploy) and fill secrets.
# fastapi-core EnvConfig uses nested keys with '__'.

# hermes-agent
HERMES_HOME="/workspaces/docmesh-doc/.hermes"
WIKI_PATH='/workspaces/docmesh-doc/wiki'

# Core runtime
DOCMESH_ENV=development
DOCMESH_HEALTHCHECK_ENABLED=true
DOCMESH_SERVICES='postgres,minio,keycloak'
DOCMESH_REQUIRED_SERVICES='postgres,minio,keycloak'

# Keycloak (required by docmesh-py-core settings validation)
KEYCLOAK_URL=http://192.168.219.106:8080
KEYCLOAK_REALM=docmesh
KEYCLOAK_CLIENT_ID=document
KEYCLOAK_CLIENT_SECRET=replace-me
KEYCLOAK_USERNAME=test
KEYCLOAK_PASSWORD=test

# Metadata store
POSTGRES_DSN='postgresql+psycopg://postgres:postgres@postgres:5432/postgres'
POSTGRES_HOST=http://postgres

# Object storage
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=default
MINIO_SECURE=false




# Runtime
TZ='Asia/Seoul'
ROOT_PATH=/
TOKEN_URL=/token

# Logging
LOGGING__LEVEL=DEBUG

# Database
# Prefer DB__URL when you already have a full DSN.
# If DB__URL is set, the individual DB__* fields are ignored.
DB__URL=
DB__HOST=postgres
DB__PORT=5432
DB__NAME=postgres
DB__USER=postgres
DB__PASSWORD=postgres
DB__AUTH_METHOD=password
DB__SSLMODE=prefer
DB__CONNECT_TIMEOUT=5
DB__ECHO=false
DB__POOL_SIZE=5
DB__MAX_OVERFLOW=10
DB__POOL_TIMEOUT=30
DB__POOL_RECYCLE=1800

# MinIO
MINIO__ENDPOINT=minio:9000
MINIO__ACCESS_KEY=admin
MINIO__SECRET_KEY=password123
MINIO__SECURE=false
MINIO__BUCKET=default
MINIO__PRESIGNED_EXPIRES_SEC=900

NATS__SERVERS='nats://192.168.219.106:4222'
NATS__NAME=docmesh-doc
NATS__CONNECT_TIMEOUT=2
NATS__MAX_RECONNECT_ATTEMPTS=60
NATS__RECONNECT_TIME_WAIT_MS=2000
NATS__QUEUE_GROUP=default-workers
