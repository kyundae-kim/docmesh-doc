# Common
TZ='Asia/Seoul'
LOGGING_LEVEL='INFO'
ENV="dev"

# keycloak
KEYCLOAK_HTTP_URL="http://keycloak:8080/"
KEYCLOAK_MANAGE_URL="http://keycloak:9000/"
KEYCLOAK_REALM="restapi"
KEYCLOAK_CLIENT_ID="fastapi"

# CORS
CORS_ORIGINS="*"
CORS_CREDENTIALS=false

# auth
AUTH_VERTIFY_JWT=false

# minio
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="admin"
MINIO_SECRET_KEY="password123"
MINIO_BUCKET_NAME="docmesh"
